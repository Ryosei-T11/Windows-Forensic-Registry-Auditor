<UserControl x:Class="ForensicAuditor.UI.Dashboard.Controls.CircularProgressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="150" Width="150">
    <Grid>
        <Ellipse Stroke="#E0E0E0" StrokeThickness="10"/>
        <Ellipse Stroke="#E74C3C" StrokeThickness="10" 
                 StrokeDashArray="10 100" RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform Angle="-90"/>
            </Ellipse.RenderTransform>
        </Ellipse>
        <TextBlock Text="Secured" HorizontalAlignment="Center" VerticalAlignment="Center" 
                   FontSize="16" FontWeight="Bold" Foreground="#2ECC71"/>
    </Grid>
</UserControl>